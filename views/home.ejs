<!DOCTYPE html>
<html lang="en" class="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Gearshift Rentals</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <script>
    tailwind.config = {
      darkMode: 'class',
    };
  </script>

  <style>
    body {
      font-family: Inter, sans-serif;
    }
  </style>
</head>

<body
  class="bg-white text-black dark:bg-neutral-900 dark:text-white min-h-screen flex flex-col transition-colors duration-300">

  <header class="w-full bg-white dark:bg-neutral-900 border-b dark:border-neutral-800">
    <div class="max-w-7xl mx-auto flex justify-between items-center px-4 py-5">

      <h1 class="text-3xl font-extrabold tracking-tight leading-none">
        GEARSHIFT
        <span class="text-yellow-500 inline-block align-bottom translate-y-[4px]">
          &#9642;
        </span>
      </h1>

      <nav class="hidden md:flex gap-8 text-base font-medium">

        <a href="/api/v1/all-cars" target="_blank"
          class="px-4 py-2 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition">
          <span class="mx-1 text-green-400 font-black">/</span>
          <span class="text-neutral-700 dark:text-neutral-300">all-cars</span>
        </a>

        <a href="/api/v1/single-car/1" target="_blank"
          class="px-4 py-2 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition">
          <span class="mx-1 text-green-400 font-black">/</span>
          <span class="text-neutral-700 dark:text-neutral-300">single-car</span>
        </a>

        <a href="/api/v1/all-non-approved-bookings" target="_blank"
          class="px-4 py-2 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition">
          <span class="mx-1 text-green-400 font-black">/</span>
          <span class="text-neutral-700 dark:text-neutral-300">all-non-approved-bookings</span>
        </a>

        <a href="/api/v1/all-approved-bookings" target="_blank"
          class="px-4 py-2 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition">
          <span class="mx-1 text-green-400 font-black">/</span>
          <span class="text-neutral-700 dark:text-neutral-300">all-approved-bookings</span>
        </a>

      </nav>

      <div class="flex gap-3 items-center">

        <a href="https://github.com/rehmankalawant/gearshift-rentals-backend-api-with-database.git" target="_blank"
          class="hidden md:inline-flex px-4 py-2 text-sm font-medium bg-black text-white dark:bg-white dark:text-black hover:opacity-80 transition">
          GITHUB
        </a>

        <a href="https://gearshift-rentals-backend-api.onrender.com/gearshift-api-docs/" target="_blank"
          class="hidden md:inline-flex px-5 py-2 text-sm font-medium bg-yellow-400 text-black hover:bg-yellow-500/90 transition">
          SWAGGER UI
        </a>

        <button id="themeToggle"
          class="w-10 h-10 flex items-center justify-center border dark:border-neutral-700 rounded hover:bg-neutral-100 dark:hover:bg-neutral-800 transition">

          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path
              d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401" />
          </svg>

        </button>

      </div>

    </div>
  </header>

  <main class="flex-1 flex items-center justify-center px-6">
    <div class="max-w-4xl mx-auto text-center">

      <h1 class="text-5xl md:text-7xl font-extrabold leading-tight tracking-tight">
        Gearshift API.
        <br />
        <span class="bg-yellow-400 text-black px-4 py-1 inline-block mt-3">
          Made With Express Js.
        </span>
        <br />
        DB Supported.
      </h1>

      <p class="mt-6 text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        Access, manage, and control car rental data through structured REST APIs —
        including cars, bookings, and approval workflows.
      </p>

      <div class="mt-10 flex justify-center gap-4 flex-wrap">

        <a href="https://github.com/rehmankalawant/gearshift-rentals-backend-api-with-database.git"
          class="px-7 py-3 font-medium bg-black text-white dark:bg-white dark:text-black hover:opacity-80 transition">
          Github →
        </a>

        <a href="https://gearshift-rentals-backend-api.onrender.com/gearshift-api-docs/"
          class="px-7 py-3 font-medium bg-yellow-400 text-black hover:bg-yellow-500/90 transition">
          Swagger UI →
        </a>

      </div>

    </div>
  </main>

  <footer class="bg-white dark:bg-neutral-900 border-t dark:border-neutral-800">
    <div
      class="max-w-7xl mx-auto px-8 md:px-10 py-6 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
      <p>© <%= new Date().getFullYear() %> Gearshift Rentals</p>

      <div class="flex gap-8">
        <a href="#" class="hover:text-yellow-400 transition">
          Privacy
        </a>
        <a href="#" class="hover:text-yellow-400 transition">
          Terms
        </a>
      </div>
    </div>
  </footer>

  <script>
    const toggleBtn = document.getElementById('themeToggle');
    const html = document.documentElement;

    const moonIcon = `
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
      fill="none" stroke="currentColor" stroke-width="2"
      stroke-linecap="round" stroke-linejoin="round">
      <path d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401"/>
    </svg>
  `;

    const sunIcon = `
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
      fill="none" stroke="currentColor" stroke-width="2"
      stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="4"/>
      <path d="M12 2v2"/><path d="M12 20v2"/>
      <path d="m4.93 4.93 1.41 1.41"/>
      <path d="m17.66 17.66 1.41 1.41"/>
      <path d="M2 12h2"/><path d="M20 12h2"/>
      <path d="m6.34 17.66-1.41 1.41"/>
      <path d="m19.07 4.93-1.41 1.41"/>
    </svg>
  `;

    // Load saved theme
    if (localStorage.getItem('theme') === 'dark') {
      html.classList.add('dark');
      toggleBtn.innerHTML = sunIcon;
    } else {
      toggleBtn.innerHTML = moonIcon;
    }

    toggleBtn.addEventListener('click', () => {
      html.classList.toggle('dark');

      if (html.classList.contains('dark')) {
        localStorage.setItem('theme', 'dark');
        toggleBtn.innerHTML = sunIcon;
      } else {
        localStorage.setItem('theme', 'light');
        toggleBtn.innerHTML = moonIcon;
      }
    });
  </script>

</body>

</html>